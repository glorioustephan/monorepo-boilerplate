{
  "name": "@monorepo-boilerplate/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Tailwind v4 UI kit. Consumed directly from source so consuming apps get HMR.",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./registry": "./src/registry.ts",
    "./catalog-schema": "./src/catalog-schema.ts",
    "./styles.css": "./src/styles.css",
    "./themes/*": "./src/themes/*.css"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "radix-ui": "catalog:",
    "tailwind-merge": "catalog:"
  },
  "devDependencies": {
    "@monorepo-boilerplate/test-config": "workspace:*",
    "@monorepo-boilerplate/ts-config": "workspace:*",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "jsdom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  }
}
