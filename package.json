{
  "name": "monorepo-boilerplate",
  "version": "0.0.0",
  "private": true,
  "description": "Opinionated Turborepo + pnpm monorepo boilerplate (Next.js 16, React 19, MCP, oxc).",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "storybook": "turbo run storybook --filter=@monorepo-boilerplate/ui",
    "build-storybook": "turbo run build-storybook --filter=@monorepo-boilerplate/ui",
    "docs:dev": "turbo run dev --filter=@monorepo-boilerplate/docs",
    "docs:build": "turbo run build --filter=@monorepo-boilerplate/docs",
    "docs:preview": "turbo run preview --filter=@monorepo-boilerplate/docs",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:tokens": "tsx tooling/catalog-lint/src/check-tokens.ts",
    "lint:catalog": "tsx tooling/catalog-lint/src/check-catalog.ts",
    "ui:codegen": "tsx tooling/catalog-codegen/src/cli.ts && oxfmt --write packages/ui/src/components",
    "ui:codegen:check": "pnpm ui:codegen && test -z \"$(git status --porcelain -- packages/ui/src/components)\"",
    "lint:smells": "tsx tooling/catalog-lint/src/check-smells.ts",
    "todos:generate": "tsx tooling/annotations/src/cli.ts --write docs/todo.md && oxfmt --write docs/todo.md",
    "todos:check": "pnpm todos:generate && git diff --exit-code -- docs/todo.md",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:e2e": "turbo run test:e2e",
    "clean": "turbo run clean && rm -rf node_modules",
    "env:doctor": "turbo run env:doctor",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "turbo run build && changeset publish",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@changesets/cli": "catalog:",
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "lefthook": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "tsx": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.1.0"
}
