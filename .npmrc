# Strict, reproducible installs for the monorepo.
engine-strict=true
auto-install-peers=true
dedupe-peer-dependents=true
# Hoist only the tooling that benefits from it; keep the rest isolated for correctness.
public-hoist-pattern[]=*oxlint*
public-hoist-pattern[]=*oxfmt*
public-hoist-pattern[]=*types*
