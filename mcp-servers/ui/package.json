{
  "name": "@monorepo-boilerplate/mcp-ui",
  "version": "0.0.0",
  "private": true,
  "description": "Internal MCP server exposing the UI kit's component registry to agents.",
  "bin": {
    "monorepo-boilerplate-ui-mcp": "./dist/index.mjs"
  },
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS=--experimental-sqlite tsx watch src/index.ts",
    "build-catalog": "NODE_OPTIONS=--experimental-sqlite tsx scripts/build-catalog.ts",
    "build": "pnpm build-catalog && tsdown",
    "start": "node --experimental-sqlite dist/index.mjs",
    "typecheck": "tsc --noEmit",
    "test": "NODE_OPTIONS=--experimental-sqlite vitest run",
    "test:unit": "NODE_OPTIONS=--experimental-sqlite vitest run"
  },
  "dependencies": {
    "@huggingface/transformers": "catalog:",
    "@modelcontextprotocol/sdk": "catalog:",
    "@monorepo-boilerplate/logger": "workspace:*",
    "@monorepo-boilerplate/ui": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@monorepo-boilerplate/test-config": "workspace:*",
    "@monorepo-boilerplate/ts-config": "workspace:*",
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
