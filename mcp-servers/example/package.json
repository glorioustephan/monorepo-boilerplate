{
  "name": "@monorepo-boilerplate/mcp-example",
  "version": "0.0.0",
  "private": true,
  "description": "Hello-world Model Context Protocol server (stdio transport).",
  "bin": {
    "monorepo-boilerplate-mcp": "./dist/index.mjs"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsdown",
    "start": "node dist/index.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "catalog:",
    "@monorepo-boilerplate/logger": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@monorepo-boilerplate/test-config": "workspace:*",
    "@monorepo-boilerplate/ts-config": "workspace:*",
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
