# Web app environment. Copy to `.env.local` and fill in. Validated by src/env.ts
# (see src/env.schema.ts). Run `pnpm --filter @monorepo-boilerplate/web env:doctor`.

# Session signing secret (HMAC). REQUIRED in production — set a 32+ char random
# value. A weak dev default is used if unset, which is insecure for real deploys.
#   generate: openssl rand -base64 32
SESSION_SECRET=

# Webhook HMAC secret (min 16 chars). Optional; if unset, POST /api/webhooks/*
# fails closed (rejects all requests) rather than accepting forged payloads.
WEBHOOK_SECRET=

# Public app name — exposed to the browser (NEXT_PUBLIC_*).
NEXT_PUBLIC_APP_NAME=monorepo-boilerplate