{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/oxfmt-file.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/check-tokens-file.sh"
          }
        ]
      }
    ]
  }
}
