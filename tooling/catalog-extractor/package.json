{
  "name": "@monorepo-boilerplate/catalog-extractor",
  "version": "0.0.0",
  "private": true,
  "description": "Build-time catalog generator: reads ui sidecars + source, writes registry.generated.ts. Never imported at runtime by ui or the servers.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@monorepo-boilerplate/ui": "workspace:*",
    "ts-morph": "catalog:"
  },
  "devDependencies": {
    "@monorepo-boilerplate/test-config": "workspace:*",
    "@monorepo-boilerplate/ts-config": "workspace:*",
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
