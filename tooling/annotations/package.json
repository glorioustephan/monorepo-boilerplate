{
  "name": "@monorepo-boilerplate/annotations",
  "version": "0.0.0",
  "private": true,
  "description": "Harvests code annotations (TODO/FIXME/HACK/@deprecated) across every language into docs/todo.md. Deterministic, regenerated from source.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run"
  },
  "devDependencies": {
    "@monorepo-boilerplate/test-config": "workspace:*",
    "@monorepo-boilerplate/ts-config": "workspace:*",
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
